generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum TestimonialStatus {
  DRAFT
  PUBLISHED
}

enum EmailStatus {
  SENT
  FAILED
}

enum AdminRole {
  SUPERADMIN
  STAFF
}

model Sequence {
  id         Int      @id
  lastNumber Int      @default(999)
  updatedAt  DateTime @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  address   String
  city      String
  createdAt DateTime @default(now())
  orders    Order[]
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  brand       String
  description String        @db.Text
  price       Decimal       @db.Decimal(12, 2)
  salePrice   Decimal?      @db.Decimal(12, 2)
  saleEndsAt  DateTime?
  images      Json
  videoUrl    String?
  stock       Int           @default(0)
  status      ProductStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customerId    String
  customerPhone String
  customer      Customer    @relation(fields: [customerPhone], references: [phone])
  items         Json
  subtotal      Decimal     @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  status        OrderStatus @default(PENDING)
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Testimonial {
  id            String             @id @default(cuid())
  customerName  String
  customerImage String
  rating        Int
  reviewText    String             @db.Text
  status        TestimonialStatus  @default(DRAFT)
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model SiteSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model EmailLog {
  id        String      @id @default(cuid())
  toEmail   String
  subject   String
  template  String
  status    EmailStatus
  sentAt    DateTime    @default(now())
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(SUPERADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
